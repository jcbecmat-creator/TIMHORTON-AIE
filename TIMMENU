        </main>
    </div>

    <div id="camera-overlay"><div id="camera-stream"><video id="camera-video" autoplay="true"></video></div><div class="camera-controls"><button class="draft-btn" onclick="closeCamera()"><i data-lucide="x"></i> Cerrar</button><button class="btn-photo" onclick="captureFoto()"><i data-lucide="camera"></i> Capturar</button></div></div>
    <div id="photoModal" class="modal-enlarger" onclick="this.style.display='none'"><img class="modal-content-img" id="imgFull"></div>

    <script>
        lucide.createIcons();

        // Navegación SPA
        function cambiarVista(event, idVista) {
            if(event) event.preventDefault();
            document.querySelectorAll('.modulo-vista').forEach(v => v.classList.remove('activa'));
            document.querySelectorAll('.sidebar-link').forEach(l => l.classList.remove('activa'));
            document.getElementById(idVista).classList.add('activa');
            if(event) event.currentTarget.classList.add('activa');
            
            const sidebar = document.getElementById('sidebar');
            if (window.innerWidth <= 1024 && sidebar && sidebar.classList.contains('open')) { sidebar.classList.remove('open'); }
        }

        const toggles = document.querySelectorAll('[data-sidebar-toggle]');
        toggles.forEach(toggle => { toggle.addEventListener('click', () => document.getElementById('sidebar').classList.toggle('open')); });
        document.querySelector('[data-sidebar-close]').addEventListener('click', () => document.getElementById('sidebar').classList.remove('open'));

        // CÁMARA Y FOTOS
        let fotosData = [null, null, null];
        function countFotos() { return fotosData.filter(f => f !== null).length; }
        function addPhotoData(dataUrl) { const slotVacio = fotosData.findIndex(f => f === null); if(slotVacio === -1) { alert("Máximo 3 fotos permitidas."); return; } fotosData[slotVacio] = dataUrl; renderSlots(); }
        function triggerFile() { if(countFotos() < 3) document.getElementById('fileInput').click(); else alert("Máximo 3 fotos permitidas."); }
        function addPhoto(input) { if (!input.files || input.files.length === 0) return; const file = input.files[0]; const reader = new FileReader(); reader.onload = function(e) { addPhotoData(e.target.result); input.value = ''; }; reader.readAsDataURL(file); }

        const overlay = document.getElementById('camera-overlay');
        const video = document.getElementById('camera-video');
        const canvasT = document.getElementById('tempCanvas');
        let currentStream;

        async function triggerCamera() {
            if(countFotos() >= 3) { alert("Máximo 3 fotos permitidas."); return; }
            try { currentStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } }); video.srcObject = currentStream; overlay.style.display = 'flex'; } catch (err) { alert("No se pudo acceder a la cámara."); }
        }
        function closeCamera() { if (currentStream) { currentStream.getTracks().forEach(track => track.stop()); } overlay.style.display = 'none'; }
        function captureFoto() { const ctx = canvasT.getContext('2d'); canvasT.width = video.videoWidth; canvasT.height = video.videoHeight; ctx.drawImage(video, 0, 0, canvasT.width, canvasT.height); addPhotoData(canvasT.toDataURL('image/jpeg', 0.8)); closeCamera(); }
        function removeFoto(index) { fotosData[index] = null; renderSlots(); }
        
        function renderSlots() {
            for (let i = 0; i < 3; i++) {
                const slot = document.getElementById(`slot-${i}`);
                if (fotosData[i]) { slot.innerHTML = `<img src="${fotosData[i]}" onclick="enlargePhoto(this.src)"><span class="remove-photo" onclick="removeFoto(${i})">&times;</span>`; slot.style.border = "1px solid #eee"; } 
                else { slot.innerHTML = `<i data-lucide="image" class="slot-placeholder-icon"></i>`; slot.style.border = "2px dashed var(--gray-300)"; }
            }
            lucide.createIcons();
        }
        function enlargePhoto(src){ document.getElementById('photoModal').style.display = "block"; document.getElementById('imgFull').src = src; }

        // FIX DEFINITIVO: FIRMA TÁCTIL
        const canvasFirma = document.getElementById('firma_tecnico');
        const ctxFirma = canvasFirma.getContext('2d');
        
        canvasFirma.width = 600;
        canvasFirma.height = 200;
        ctxFirma.lineWidth = 3;
        ctxFirma.lineCap = 'round';
        ctxFirma.strokeStyle = '#000000';

        let isDrawing = false;

        function getCoordinates(e) {
            const rect = canvasFirma.getBoundingClientRect();
            const clientX = e.touches ? e.touches[0].clientX : e.clientX;
            const clientY = e.touches ? e.touches[0].clientY : e.clientY;
            const scaleX = canvasFirma.width / rect.width;
            const scaleY = canvasFirma.height / rect.height;
            return { x: (clientX - rect.left) * scaleX, y: (clientY - rect.top) * scaleY };
        }

        canvasFirma.addEventListener('mousedown', (e) => { isDrawing = true; const pos = getCoordinates(e); ctxFirma.beginPath(); ctxFirma.moveTo(pos.x, pos.y); });
        canvasFirma.addEventListener('mousemove', (e) => { if (isDrawing) { const pos = getCoordinates(e); ctxFirma.lineTo(pos.x, pos.y); ctxFirma.stroke(); } });
        window.addEventListener('mouseup', () => { if(isDrawing) { isDrawing = false; document.getElementById('firma_tecnico_data').value = canvasFirma.toDataURL(); } });

        canvasFirma.addEventListener('touchstart', (e) => { e.preventDefault(); isDrawing = true; const pos = getCoordinates(e); ctxFirma.beginPath(); ctxFirma.moveTo(pos.x, pos.y); }, {passive: false});
        canvasFirma.addEventListener('touchmove', (e) => { e.preventDefault(); if (isDrawing) { const pos = getCoordinates(e); ctxFirma.lineTo(pos.x, pos.y); ctxFirma.stroke(); } }, {passive: false});
        window.addEventListener('touchend', () => { if(isDrawing) { isDrawing = false; document.getElementById('firma_tecnico_data').value = canvasFirma.toDataURL(); } });

        function limpiarFirma(id) {
            ctxFirma.clearRect(0, 0, canvasFirma.width, canvasFirma.height);
            document.getElementById(id+'_data').value = '';
        }

        renderSlots();
    </script>
</body>
</html>
